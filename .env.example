# Cursor SDK — required for live agent calls (server + Vercel api/claude)
CURSOR_API_KEY=your_key_here

# Optional: override default model (composer-2.5)
# LLM_MODEL=composer-2.5

# Set to true for cached demo mode (no live agent calls)
# VITE_DEMO_MODE=false

# Vercel: add CURSOR_API_KEY in Project Settings → Environment Variables
# VITE_DEMO_MODE must be set at BUILD time if you want demo mode in production
